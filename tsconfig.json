{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "moduleResolution": "node",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "outDir": "./dist",
        "rootDir": ".",
        "types": ["node"]
    },
    "include": ["src/**/*", "wdio.conf.ts"],
    "exclude": ["node_modules", "dist"]
}
