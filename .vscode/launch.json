{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "wdio debug",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run-script",
        "test"
      ],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "DEBUG": "true"
      }
    }
  ]
}