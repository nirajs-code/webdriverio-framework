# Runtime environment (maps to conf/env/<ENV>/config.json)
ENV=test
OVERWRITE_URL=

# Tag expression to filter scenarios  e.g. @smoke, @smoke and not @skip
TAG=@smoke

# Platform: desktop | mobile
PLATFORM=desktop

# Browser: chrome | firefox | edge  (desktop only — mobile always uses Chrome emulation)
BROWSER=chrome

# Mobile device name — Chrome DevTools preset for local/headless, BrowserStack device for remote
# Examples: 'iPhone 12 Pro', 'Pixel 5', 'Samsung Galaxy S8+', 'iPad Air'
MOBILE_DEVICE=iPhone 12 Pro

# BrowserStack real device OS version (used when PLATFORM=mobile + test:browserstack)
MOBILE_OS_VERSION=16

# Parallelism and retries
MAX_INSTANCE=1
MAX_RETRY=0

# Enable verbose driver logs and Node inspector (attach via chrome://inspect)
DEBUG=

# Override network timeout (ms) for slow environments
DEFAULT_NETWORK_TIMEOUT=120000

# BrowserStack (required for: npm run test:browserstack)
BROWSERSTACK_USERNAME=
BROWSERSTACK_ACCESS_KEY=
BUILD_NAME=local

# BrowserStack Test Observability (optional — set to true to enable)
BS_TEST_OBSERVABILITY=false
BS_TESTOBS_USERNAME=
BS_TESTOBS_ACCESS_KEY=
