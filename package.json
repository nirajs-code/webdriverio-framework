{
  "name": "wdio_test",
  "devDependencies": {
    "@axe-core/webdriverio": "^4.11.2",
    "@gmangiapelo/wdio-azure-devops-service": "^0.1.0",
    "@types/node": "^25.6.0",
    "@wdio/allure-reporter": "^9.27.0",
    "@wdio/browserstack-service": "^9.27.0",
    "@wdio/cli": "^9.27.0",
    "@wdio/cucumber-framework": "^9.27.0",
    "@wdio/json-reporter": "^9.20.0",
    "@wdio/junit-reporter": "^9.27.0",
    "@wdio/lighthouse-service": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "@wdio/types": "^9.27.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.1",
    "wdio-cucumberjs-json-reporter": "^6.0.1"
  },
  "scripts": {
    "test":                   "wdio run ./conf/wdio.conf.ts",
    "test:headless":          "wdio run ./conf/wdio.headless.conf.ts",
    "test:browserstack":      "wdio run ./conf/wdio.browserstack.conf.ts",
    "test:isolated":          "wdio run ./conf/wdio.isolatedSession.conf.ts",
    "test:isolated:headless": "HEADLESS=true wdio run ./conf/wdio.isolatedSession.conf.ts",
    "test:dry":               "wdio run ./conf/wdio.conf.ts --cucumberOpts.dryRun=true",
    "lint":                   "eslint .",
    "lint:fix":               "eslint . --fix",
    "format":                 "prettier --write \"**/*.{ts,json,feature}\"",
    "format:check":           "prettier --check \"**/*.{ts,json,feature}\"",
    "prepare":                "husky"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
