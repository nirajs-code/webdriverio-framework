{
    "printWidth": 120,
    "tabWidth": 4,
    "useTabs": false,
    "semi": false,
    "singleQuote": true,
    "quoteProps": "as-needed",
    "trailingComma": "es5",
    "bracketSpacing": true,
    "arrowParens": "avoid",
    "endOfLine": "lf",
    "overrides": [
        {
            "files": ["*.json", "*.jsonc"],
            "options": {
                "tabWidth": 2,
                "trailingComma": "none"
            }
        },
        {
            "files": ["*.feature"],
            "options": {
                "tabWidth": 2,
                "singleQuote": false
            }
        }
    ]
}
